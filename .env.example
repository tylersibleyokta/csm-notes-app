# Direct Postgres connection string (a plain postgres:// URL, not the
# prisma+postgres:// Accelerate one). If using Vercel's "Prisma Postgres"
# storage integration, this is the POSTGRES_URL value it gives you, not
# PRISMA_DATABASE_URL. Local dev can point at the same instance.
DATABASE_URL=

# Base URL this app is running at (used to build OAuth redirect URIs)
APP_BASE_URL="http://localhost:3000"

# Claude API (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Server-side secret used to encrypt stored Google refresh tokens.
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# NextAuth session signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth client used ONLY for the "Connect Google Tasks" linking flow
# (Google Cloud Console -> APIs & Services -> Credentials -> OAuth client ID,
# type "Web application"; enable the Google Tasks API on the project;
# add {APP_BASE_URL}/api/google/callback as an authorized redirect URI).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Okta OIDC app (Okta Admin Console -> Applications -> Create App Integration
# -> OIDC, Web Application; add {APP_BASE_URL}/api/auth/callback/okta as a
# sign-in redirect URI). Leave all three unset to use the local dev-mode
# login stub instead.
OKTA_ISSUER=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
